# Copernicus Data Space Ecosystem — Sentinel Hub OAuth client
# Register free at https://dataspace.copernicus.eu/ then create an OAuth client
# under Sentinel Hub dashboard -> User settings -> OAuth clients.
VITE_SH_CLIENT_ID=your-client-id
VITE_SH_CLIENT_SECRET=your-client-secret

# Production only: Cloudflare Worker token-proxy URL (see deploy/cloudflare-worker.js).
# Leave empty for local dev — the Vite proxy handles the token exchange.
# VITE_TOKEN_PROXY_URL=https://cdse-token.<you>.workers.dev
